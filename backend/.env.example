# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
# Local: mongodb://localhost:27017/traffic_management
# Production: mongodb+srv://user:password@cluster.mongodb.net/traffic_management?retryWrites=true
MONGODB_URI=mongodb://localhost:27017/traffic_management

# JWT Configuration (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=replace_with_long_random_access_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret_min_32_chars
JWT_REFRESH_TTL=30d

# Payment Configuration
PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER=razorpay
# RAZORPAY_KEY_ID=rzp_live_or_test_key_id
# RAZORPAY_KEY_SECRET=rzp_live_or_test_key_secret
# RAZORPAY_WEBHOOK_SECRET=webhook_secret_from_dashboard

# CORS Configuration
# Development: * (allow all)
# Production: https://yourdomain.com or https://yourdomain1.com,https://yourdomain2.com
CORS_ORIGIN=*

# ML Backend Configuration
ML_BACKEND_URL=http://localhost:8000
ML_ENABLED=false

# Default Users (Change in production!)
DEFAULT_ADMIN_EMAIL=admin@traffic.gov
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_PHONE=9999999999

DEFAULT_CITIZEN_EMAIL=citizen@example.com
DEFAULT_CITIZEN_PASSWORD=citizen123
DEFAULT_CITIZEN_PHONE=9876543210
