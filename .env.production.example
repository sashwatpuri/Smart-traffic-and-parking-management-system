# Environment Configuration - Smart Traffic ML System
# Copy this file to .env and fill in your actual values

# ==================== ML BACKEND CONFIGURATION ====================
# Python ML API Backend (FastAPI)
ML_BACKEND_URL=http://localhost:8000
ML_ENABLED=true
ML_INFERENCE_TIMEOUT=30000

# ==================== DATABASE CONFIGURATION ====================
# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/smart_traffic
DB_NAME=smart_traffic
DB_USER=admin
DB_PASSWORD=your_password

# MongoDB Atlas (Cloud - uncomment and fill if using Atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_traffic?retryWrites=true&w=majority

# ==================== SERVER CONFIGURATION ====================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
CORS_ORIGIN=*

# ==================== AUTHENTICATION ====================
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Default Admin User
DEFAULT_ADMIN_EMAIL=admin@traffic.local
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_PHONE=+919876543210

# Default Citizen User
DEFAULT_CITIZEN_EMAIL=citizen@traffic.local
DEFAULT_CITIZEN_PASSWORD=Citizen@123
DEFAULT_CITIZEN_PHONE=+919876543211

# ==================== FILE UPLOAD CONFIGURATION ====================
MAX_FILE_SIZE=104857600  # 100MB in bytes
UPLOAD_DIR=uploads
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv

# ==================== CAMERA CONFIGURATION ====================
CAMERA_IPS=192.168.1.100,192.168.1.101,192.168.1.102,192.168.1.103
DEFAULT_CAMERA_PORT=8080
CAMERA_USERNAME=admin
CAMERA_PASSWORD=camera_password

# ==================== TRAFFIC SIGNAL CONFIGURATION ====================
SIGNAL_CONTROLLERS_IP=192.168.1.50
DEFAULT_GREEN_TIME=30
DEFAULT_YELLOW_TIME=5
DEFAULT_RED_TIME=35

# ==================== FINE & CHALLAN CONFIGURATION ====================
HELMET_VIOLATION_FINE=500
SPEEDING_VIOLATION_BASE_FINE=100
SIGNAL_VIOLATION_FINE=1000
ILLEGAL_PARKING_FINE=1000
ENCROACHMENT_FINE=2000

# ==================== PAYMENT GATEWAY ====================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=test_xxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxx

# ==================== EMAIL CONFIGURATION ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=noreply@traffic.local
SENDER_NAME=Smart Traffic System

# ==================== NOTIFICATION CONFIGURATION ====================
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=TRAFFIC
WHATSAPP_API_KEY=your_whatsapp_api_key

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ==================== FEATURE FLAGS ====================
ENABLE_LIVE_STREAMING=true
ENABLE_ML_DETECTION=true
ENABLE_AUTO_CHALLAN=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false

# ==================== PERFORMANCE TUNING ====================
DB_POOL_SIZE=10
CACHE_TTL=300
SESSION_TIMEOUT=3600

# ==================== FIREBASE (Optional) ====================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# ==================== GOOGLE API (Optional) ====================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key

# ==================== DEBUG MODE ====================
DEBUG=false
VERBOSE=false
MOCK_MODE=false
